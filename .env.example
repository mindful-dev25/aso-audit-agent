# ── LLM ───────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Firecrawl (optional) ───────────────────────────────────────────────────────
# Enables scraping the App Store page for subtitle and promotional text.
# Without this key the audit still works — it just won't include those fields.
FIRECRAWL_API_KEY=

# ── Mastra storage (optional) ─────────────────────────────────────────────────
# When not set, uses in-memory storage (no persistence across restarts).
# For local persistence: file:./mastra.db
# For production (Netlify/serverless): use a Turso libsql URL instead.
MASTRA_DB_URL=file:./mastra.db
# MASTRA_DB_URL=libsql://your-db.turso.io?authToken=...
